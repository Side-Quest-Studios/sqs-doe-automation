# ============================================================
# SQS DOE Automation — Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual keys.
# NEVER commit .env to git. It's in .gitignore.
# ============================================================

# ===== Tier 1: Core (Required Day 1) =====
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx
NOTION_API_KEY=ntn_xxxxxxxxxxxxx
APIFY_API_TOKEN=apify_api_xxxxxxxxxxxxx

# ===== Tier 2: Lead Gen & Outreach (Required Day 2-3) =====
ANYMAILFINDER_API_KEY=xxxxxxxxxxxxx
INSTANTLY_API_KEY=xxxxxxxxxxxxx
GOOGLE_APPLICATION_CREDENTIALS=./credentials.json

# ===== Tier 3: Content & Social (Required Week 1-2) =====
BUFFER_ACCESS_TOKEN=xxxxxxxxxxxxx
TWITTER_BEARER_TOKEN=xxxxxxxxxxxxx
OPENCLAW_API_KEY=xxxxxxxxxxxxx

# ===== Tier 4: Webhooks & Notifications (Required Week 3-4) =====
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxxxxxxxxxxxx

